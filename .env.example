# 豆包（火山引擎）配置
OPENAI_API_KEY=your_openai_api_key_here
BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MODEL_NAME=your_model_endpoint_id

# DeepSeek 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 通义千问（阿里云百炼 DashScope，OpenAI 兼容模式）
# 也可使用 DASHSCOPE_API_KEY 作为 apiKey
QWEN_API_KEY=your_dashscope_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Token 预算（可选，降低 prompt 消耗）
# AGENT_MAX_HISTORY_TURNS=8
# AGENT_MAX_HISTORY_CHARS=12000
# AGENT_MAX_MESSAGE_CHARS=4000
# AGENT_MAX_TOOL_RESULT_CHARS=2000
# AGENT_COMPACT_SYSTEM_PROMPT=1
# DEBUG_AGENT=1
